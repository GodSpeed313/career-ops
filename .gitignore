# Personal data (user fills these)
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config and customization (never auto-updated)
config/profile.yml
config/projects.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Generated
.resolved-prompt-*
node_modules/

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
career-dashboard
package-lock.json

# SECURITY: Private projects should NOT be committed to public repo
# These should be symlinked or referenced externally only
# DO NOT UNCOMMENT UNLESS MOVING THESE INTO THIS REPO:
# /Teplit/
# /WorldCraft-Visuals/
# /Melody-Maestro/

# If you DO include private projects, add explicit rules:
# Teplit/ - PRIVATE: Personal Replit clone in development
# WorldCraft-Visuals/ - Consider private if unreleased
# */node_modules/ - Project dependencies
# */dist/ - Build outputs
# */.env - Environment variables
# */build/ - Build artifacts
